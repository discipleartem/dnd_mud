{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dnd-mud.local/schema/v1/grant.json",
  "title": "Grant",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": { "type": "string", "minLength": 1 },
    "amount": { "type": "integer" },
    "count": { "type": "integer", "minimum": 1 },
    "choice": { "type": "boolean" },
    "per_level": { "type": "boolean" },
    "pool": { "type": "string" },
    "from": { "type": "string" },
    "skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "weapons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "armor": {
      "type": "array",
      "items": { "type": "string" }
    },
    "languages": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
